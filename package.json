{
  "name": "news-portal-backend",
  "version": "1.0.0",
  "description": "Backend for City and State News Portal",
  "main": "server.js",
  "type": "commonjs",
  "scripts": {
    "dev": "nodemon server.js",
    "start": "node server.js"
  },
  "nodemonConfig": {
    "ignore": [
      "node_modules/*",
      ".env",
      "*.log"
    ],
    "ext": "js,json",
    "delay": "500"
  },
  "keywords": [
    "news",
    "portal",
    "backend",
    "nodejs",
    "express"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "axios": "^1.15.0",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "dotenv": "^17.4.1",
    "express": "^5.2.1",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.4.1"
  },
  "devDependencies": {
    "nodemon": "^3.1.14"
  }
}
